{
  "name": "tayfa",
  "version": "0.1.0",
  "private": true,
  "description": "Tayfa — verified, location-based social app that turns shared hobbies into real-life small-group hangouts. Not a dating app.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom@<0.8.13": "^0.8.13"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-34x7-hfp2-rc4v",
        "GHSA-8qq5-rm4j-mr97",
        "GHSA-83g3-92jg-28cx",
        "GHSA-qffp-2rhf-9h96",
        "GHSA-9ppj-qmqm-q256",
        "GHSA-r6q2-hw4h-h46w"
      ]
    }
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.9.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
