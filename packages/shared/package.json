{
  "name": "@tayfa/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-monorepo contract: Zod schemas, typed analytics taxonomy, domain types, and pure business logic (RSVP state machine, feed ranking, NSM confirmation, reputation, location privacy, entitlements). Zero I/O — deterministic and exhaustively tested.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants/index.ts",
    "./types": "./src/types/index.ts",
    "./events": "./src/events/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./domain": "./src/domain/index.ts",
    "./adapters": "./src/adapters/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist coverage *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
