auto-install-peers=true
strict-peer-dependencies=false
dedupe-peer-dependents=true
prefer-workspace-packages=true
link-workspace-packages=true
save-exact=false
engine-strict=false

# Publicly hoist the Babel toolchain to the root node_modules so Expo's
# production bundler (`expo export:embed`, used by the release/standalone build)
# can resolve babel-preset-expo's transitive plugins under pnpm's strict layout.
# Targeted (not a full shamefully-hoist) — keeps strictness everywhere else.
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=babel-plugin-*
public-hoist-pattern[]=babel-preset-*
public-hoist-pattern[]=@react-native/babel-*
public-hoist-pattern[]=metro-react-native-babel-*
