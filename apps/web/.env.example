# ─────────────────────────────────────────────────────────────────────────────
# apps/web — environment template (subset of the repo-root .env.example).
# Copy values from the root .env / .env.example. Anything NOT prefixed
# NEXT_PUBLIC_* is server-only and must never reach the client bundle.
#
# The app boots fully in MOCK mode with NONE of these set — only TAYFA_PROVIDER_MODE
# matters for local/CI. Production adapters guard on their own env and fail closed.
# ─────────────────────────────────────────────────────────────────────────────

# Force every external provider into deterministic mock mode (default: mock).
TAYFA_PROVIDER_MODE=mock

# Public app origin (OG tags, share links).
NEXT_PUBLIC_APP_URL=https://tayfa.app

# Supabase (Auth session + service role for the BFF). EU / Frankfurt.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL for the Drizzle service client (BFF + T&S console).
DATABASE_URL=

# Upstash Redis (rate-limits + webhook idempotency). Optional → in-memory fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostHog (consent-gated server analytics, EU cloud).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Provider webhook secrets (signature verification — fail-closed).
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_API_KEY=

# Trust & Safety console access — comma-separated moderator user ids (allowlist).
TAYFA_MODERATOR_USER_IDS=

# Sentry (no-op without a DSN).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
