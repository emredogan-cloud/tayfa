# ─────────────────────────────────────────────────────────────────────────────
# Tayfa — Environment template. Copy to `.env` and fill in.
# Real secrets NEVER get committed (.env is git-ignored). See docs/ENVIRONMENT_SETUP.md
# for where to obtain each value (dashboard + exact clicks + pricing).
#
# Convention: anything prefixed EXPO_PUBLIC_* or NEXT_PUBLIC_* is shipped to the
# client bundle — it must be safe to expose. Everything else is server-only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development

# ── Supabase (Postgres + Auth + Realtime + Storage) — EU / Frankfurt region ──
# required. Anon key is public-safe (RLS protects data). Service role is SERVER-ONLY.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...public-safe-anon-key
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...public-safe-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...public-safe-anon-key
# SERVER-ONLY. Full god-mode. Never ship to client. Used only by the BFF service role.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-NEVER-on-client
# Direct Postgres connection for Drizzle migrations / RLS tests (CI + local).
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── AI: Vercel AI Gateway + AI SDK v6 (generative) and OpenAI (embeddings, moderation, images) ──
# Generative default model: anthropic/claude-haiku-4.5 routed via the gateway.
AI_GATEWAY_API_KEY=vck_...
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# OpenAI: text-embedding-3-small (1536-d), Moderation API, and Images API (asset gen).
OPENAI_API_KEY=sk-proj-...

# ── Async workflows: Inngest ──
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Cache / rate-limits / idempotency: Upstash Redis ──
UPSTASH_REDIS_REST_URL=https://YOUR.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Identity verification (ID + liveness): Persona ──
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_TEMPLATE_ID=itmpl_...

# ── Subscriptions: RevenueCat (entitlement source of truth) ──
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...

# ── Moderation providers ──
# Image NSFW + face checks: Hive (or AWS Rekognition via AWS_* below).
HIVE_API_KEY=
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Analytics + flags + experiments: PostHog (EU cloud) ──
EXPO_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Observability: Sentry ──
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Push (transactional, MVP): Expo Push. Lifecycle journeys (P6): Braze ──
EXPO_ACCESS_TOKEN=
BRAZE_API_KEY=
BRAZE_REST_ENDPOINT=https://rest.fra-01.braze.eu

# ── Web payouts / marketplace (P9): Stripe + Stripe Connect ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Feature flags ──
# Use a mock adapter when a provider key is absent (mission AUTONOMY RULES).
# Set to "mock" to force all external providers into deterministic mock mode (CI/dev).
TAYFA_PROVIDER_MODE=mock
